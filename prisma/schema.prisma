generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int           @id @default(autoincrement())
  name            String
  email           String        @unique
  phone           String?
  role            String        @default("staff")
  status          String        @default("active")
  passwordHash    String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  clientsCreated  Client[]      @relation("ClientCreatedBy")
  clientsAssigned Client[]      @relation("ClientAssignedStaff")
  applications    Application[] @relation("ApplicationAssignedStaff")
  stageChangesMade ApplicationStageHistory[] @relation("StageHistoryChangedBy")
  assignedTasks   Task[]        @relation("TaskAssignee")
  createdTasks    Task[]        @relation("TaskAssignedBy")
  uploadedDocuments Document[]   @relation("DocumentUploader")
  verifiedDocuments Document[]   @relation("DocumentVerifier")

  @@map("users")
}

model WorkflowStage {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  order       Int
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("workflow_stages")
}

model ServiceType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("service_types")
}

model DocumentTemplate {
  id                 Int      @id @default(autoincrement())
  name               String
  serviceType        String?
  destinationCountry String?
  isRequired         Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([name, serviceType])
  @@map("document_templates")
}

model Document {
  id               Int       @id @default(autoincrement())
  clientId         Int?
  client           Client?   @relation(fields: [clientId], references: [id])
  applicationId    Int?
  application      Application? @relation(fields: [applicationId], references: [id])
  documentType     String
  fileName         String
  fileUrl          String?
  status           String    @default("PENDING")
  verificationNotes String?
  uploadedById     Int
  uploadedBy       User      @relation("DocumentUploader", fields: [uploadedById], references: [id])
  verifiedById     Int?
  verifiedBy       User?     @relation("DocumentVerifier", fields: [verifiedById], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("documents")
}

model Client {
  id              Int           @id @default(autoincrement())
  fileNumber      String        @unique
  firstName       String
  lastName        String
  email           String
  phone           String
  address         String?
  passportNumber  String?
  dateOfBirth     DateTime?
  source          String
  createdById     Int
  createdBy       User          @relation("ClientCreatedBy", fields: [createdById], references: [id])
  assignedStaffId Int?
  assignedStaff   User?         @relation("ClientAssignedStaff", fields: [assignedStaffId], references: [id])
  applications    Application[]
  tasks           Task[]
  documents       Document[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("clients")
}

model Application {
  id                 Int      @id @default(autoincrement())
  clientId           Int
  client             Client   @relation(fields: [clientId], references: [id])
  serviceType        String
  destinationCountry String
  travelPurpose      String
  expectedTravelDate DateTime?
  currentStage       String   @default("CLIENT_INQUIRY")
  status             String   @default("NOT_STARTED")
  decisionStatus     String?
  assignedStaffId    Int?
  assignedStaff      User?    @relation("ApplicationAssignedStaff", fields: [assignedStaffId], references: [id])
  stageHistory       ApplicationStageHistory[]
  tasks              Task[]
  documents          Document[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("applications")
}

model Task {
  id            Int       @id @default(autoincrement())
  title         String
  description   String?
  clientId      Int
  client        Client    @relation(fields: [clientId], references: [id])
  applicationId Int?
  application   Application? @relation(fields: [applicationId], references: [id])
  stage         String?
  assigneeId    Int?
  assignee      User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assignedById  Int
  assignedBy    User      @relation("TaskAssignedBy", fields: [assignedById], references: [id])
  priority      String    @default("MEDIUM")
  status        String    @default("TODO")
  dueDate       DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("tasks")
}

model ApplicationStageHistory {
  id            Int         @id @default(autoincrement())
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromStage     String?
  toStage       String
  changedById   Int
  changedBy     User        @relation("StageHistoryChangedBy", fields: [changedById], references: [id])
  note          String?
  createdAt     DateTime    @default(now())

  @@map("application_stage_history")
}
