generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int      @id @default(autoincrement())
  name            String
  email           String   @unique
  phone           String?
  role            String   @default("staff")
  status          String   @default("active")
  passwordHash    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  clientsCreated  Client[] @relation("ClientCreatedBy")
  clientsAssigned Client[] @relation("ClientAssignedStaff")

  @@map("users")
}

model WorkflowStage {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  order       Int
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("workflow_stages")
}

model ServiceType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("service_types")
}

model DocumentTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  serviceType String?
  isRequired  Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("document_templates")
}

model Client {
  id              Int      @id @default(autoincrement())
  fileNumber      String   @unique
  firstName       String
  lastName        String
  email           String
  phone           String
  address         String?
  passportNumber  String?
  dateOfBirth     DateTime?
  source          String
  createdById     Int
  createdBy       User     @relation("ClientCreatedBy", fields: [createdById], references: [id])
  assignedStaffId Int?
  assignedStaff   User?    @relation("ClientAssignedStaff", fields: [assignedStaffId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("clients")
}
